if barstate.islast
    for i = 0 to array.size(times) - 1
        t = array.get(times, i)
        // @generated label-lookup
        l = lang == "EN" ? array.get(labels_en, i) : array.get(labels_pl, i)
        // @end-generated
        date = date_to_string(t)
        c = array.get(colors, i)
        visible = (c == COLOR_HIGH_PRIORITY   and show_high_priority  ) or
                  (c == COLOR_MEDIUM_PRIORITY and show_medium_priority) or
                  (c == COLOR_LOW_PRIORITY    and show_low_priority   )
        if visible
            line.new(t, low, t, high, xloc=xloc.bar_time, extend=extend.both, color=c)
            label.new(t, 0, l, xloc=xloc.bar_time, yloc=yloc.belowbar, color=c, textcolor=color.white, style=label.style_label_center, size=size.normal, tooltip=date)

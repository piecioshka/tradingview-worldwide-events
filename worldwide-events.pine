//@version=6
indicator("Worldwide Events", overlay=true, max_lines_count=500, max_labels_count=500)

COLOR_HIGH_PRIORITY   = color.rgb(166, 28, 28, 50)
COLOR_MEDIUM_PRIORITY = color.rgb(223, 134, 0, 50)
COLOR_LOW_PRIORITY    = color.rgb(255, 235, 59, 50)

// @generated lang-input
lang                 = input.string("EN", "Language", options=["EN", "PL"], group="Settings")
// @end-generated
show_high_priority   = input.bool(true,  "🔴 High priority",   group="Display events")
show_medium_priority = input.bool(true,  "🟠 Medium priority", group="Display events")
show_low_priority    = input.bool(false, "🟡 Low priority",    group="Display events")

var times     = array.new_int()
// @generated lang-arrays
var labels_en = array.new_string()
var labels_pl = array.new_string()
// @end-generated
var colors    = array.new_color()

// @generated new-event-func
new_event(int t, string l_en, string l_pl, color c = na) =>
    array.push(times, t)
    array.push(labels_en, l_en)
    array.push(labels_pl, l_pl)
    array.push(colors, na(c) ? COLOR_LOW_PRIORITY : c)
// @end-generated

date_to_string(int t) =>
    Y = year(t)
    M = month(t)
    D = dayofmonth(t)

    MM = M < 10 ? "0" + str.tostring(M) : str.tostring(M)
    DD = D < 10 ? "0" + str.tostring(D) : str.tostring(D)

    str.tostring(Y) + "-" + MM + "-" + DD

